@inject AiStateService AiState

@if (AiState.AiPanelOpen)
{
    <div class="ai-panel">

        <div class="ai-header">

            <div class="ai-title">
                🤖 AI Assistant
            </div>

            <button class="close-btn"
                    @onclick="ClosePanel">
                ✖
            </button>

        </div>

        <div class="ai-body">

            @if (AiState.AiLoading)
            {
                <div class="loading">
                    <div class="spinner"></div>
                    <span>Thinking...</span>
                </div>
            }
            else
            {
                <div class="ai-content">
                    @AiState.AiContent
                </div>
            }

        </div>

    </div>
}


<style>
    .ai-panel {
        width: 380px;
        height: 100%;
        border-left: 1px solid #ddd;
        background: #fafafa;
        display: flex;
        flex-direction: column;
    }

    .ai-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px;
        border-bottom: 1px solid #ddd;
    }

    .ai-title {
        font-weight: 600;
    }

    .close-btn {
        background: none;
        border: none;
        cursor: pointer;
    }

    .ai-body {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
    }

    .ai-content {
        white-space: pre-wrap;
        font-size: 14px;
    }

    .loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid #ccc;
        border-top: 3px solid #4f46e5;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

   
</style>
@code {

    void ClosePanel()
    {
        AiState.AiPanelOpen = false;
        AiState.Notify();
    }


    public class AiStateService
    {
        public bool AiPanelOpen { get; set; }

        public string AiContent { get; set; } = "";

        public bool AiLoading { get; set; }

        public event Action? OnChange;

        public void Notify() => OnChange?.Invoke();
    }
}

