@page "/login"
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation

<div class="min-h-screen flex items-center justify-center bg-background p-4">

    <div class="w-full max-w-md">

        <div class="bg-card rounded-2xl shadow-xl border border-border p-8">

            <div class="flex items-center justify-center gap-2 mb-8">
                <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center">
                    🧠
                </div>
                <h1 class="text-2xl font-bold text-foreground">SmartNote AI</h1>
            </div>

            <h2 class="text-xl font-semibold text-center text-foreground mb-6">
                Welcome back
            </h2>

            <EditForm OnValidSubmit="HandleSubmit">

                <div class="space-y-4">

                    <div class="space-y-2">
                        <label>Email</label>
                        <div class="relative">

                            <input type="email"
                                   placeholder="you@example.com"
                                   class="pl-10 w-full border rounded p-2"
                                   @bind="Email"
                                   required />

                        </div>
                    </div>

                    <div class="space-y-2">
                        <label>Password</label>
                        <div class="relative">

                            <input type="password"
                                   placeholder="••••••••"
                                   class="pl-10 w-full border rounded p-2"
                                   @bind="Password"
                                   required />

                        </div>
                    </div>

                    <button type="submit"
                            class="w-full h-11 text-base font-medium bg-blue-600 text-white rounded">
                        Sign In
                    </button>

                </div>

            </EditForm>

            <p class="text-center text-sm text-muted-foreground mt-6">
                Don't have an account?
                <NavLink href="/register" class="text-primary font-medium hover:underline">
                    Create one
                </NavLink>
            </p>

        </div>

    </div>

</div>

@code {

    string Email;
    string Password;

    void HandleSubmit()
    {
        if (!string.IsNullOrEmpty(Email) && !string.IsNullOrEmpty(Password))
        {
            Console.WriteLine("Login: " + Email);

            // Call API or authentication service here

            Navigation.NavigateTo("/");
        }
    }

}