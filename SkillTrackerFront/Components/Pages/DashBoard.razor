                    </svg>
                </span>
                <span class="logo-text">SmartNote AI</span>
            </div>
        </div>

        <button class="new-note-btn" @onclick="CreateNewNote">
            <span class="plus">+</span> New Note
        </button>

        <div class="search-box">
            <input type="text" placeholder="Search notes..." @bind="SearchTerm" />
        </div>

        <div class="notes-list">
            @if (notes.Any())
            {
                foreach (var note in notes)
                {
                    <div class="note-item @(note.IsSelected ? "selected" : "")"
                         @onclick="() => SelectNote(note)">
                        <div class="note-title">@note.Title
                        
                            <i class="fa-solid fa-trash delete-icon" style="color:red"
                               @onclick="@(e => DeleteNote(note, e))"></i>
                        </div>

                        <div class="note-preview">@note.NotesText</div>
                    </div>
                }
            }
            
        </div>


        <!-- Settings Section -->
        <div class="sidebar-footer">
            <div class="setting-group" style="display: flex;
                flex-direction: row;
                justify-content: space-between;">
                <label>Theme</label>
                <span class="theme-toggle" @onclick="ToggleTheme">
                    <i class="fa-solid @(isDarkMode ? "fa-sun" : "fa-moon")"></i>
                </span>
            </div>
            <div class="setting-group">
                <label>Accent Color</label>
                <input type="color" value="@accentColor" @oninput="ChangeAccentColor" />
            </div>

            <div class="setting-group">
                <label>Font</label>
                <select value="@SelectedFont" @onchange="ApplyFont" class="select-Input">
                    @foreach (var font in AvailableFonts)
                    {
                        <option value="@font">@font</option>
                    }
                </select>
            </div>

            <div class="setting-group">
                <label>Size</label>
                <select @bind="SelectedSize" class="select-Input">
                    <option>16px</option>
                    <option>18px</option>
                    <option>20px</option>
                </select>
            </div>

            <button class="signout-btn" @onclick="SignOut">
                <i class="fa-solid fa-right-from-bracket"></i>Sign Out
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <header class="top-bar">
            <div class="top-left">
                <select class="workspace-select" @bind="SelectedWorkspace">
                    <option>General</option>
                    <option>Personal</option>
                    <option>Work</option>
                </select>
            </div>

            <div class="top-right">
                <span class="icon-btn">
                    <i class="fa-solid fa-link"></i>
                </span>

                <span class="icon-btn">
                    <i class="fa-solid fa-clipboard"></i>
                </span>

                <span class="word-count">0 words</span>

                <span class="saved-status">
                    <i class="fa-solid fa-check-circle"></i> Saved
                </span>
            </div>
        </header>

         
            @if (selectedNote != null)
            {
               <div style="display:flex;justify-content:space-between">
                <input class="note-title-input"
                       placeholder="Untitled Note"
                       @bind="selectedNote.Title" style="padding-top:25px"
                       @oninput="e => AutoSave()" />

                <button class="save-btn">Save</button>
               </div>
                <main class="content-area">
                    <div class="note-editor">

                        <textarea class="note-textarea"
                                  placeholder="Start writing..."
                              @bind="selectedNote.NotesText"
                              @oninput="e => AutoSave()"></textarea>
                    </div>
                </main>
            }
            else
            {
                <div class="empty-editor">
                <svg  xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open w-12 h-12 mx-auto mb-3 opacity-40"><path d="M12 7v14"></path><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"></path></svg>
                <h2>Select a note or create a new one</h2>
                </div>
            }

        <footer class="ai-toolbar">
            <button class="ai-btn">
                <i class="fas fa-magic"></i> Summarize
            </button>

            <button class="ai-btn">
                <i class="fas fa-file-alt"></i> Explain
            </button>

            <button class="ai-btn">
                <i class="fas fa-rocket"></i> Improve
            </button>

            <button class="ai-btn">
                <i class="fas fa-question-circle"></i> Interview Q&A
            </button>
        </footer>

    </div>
</div>


