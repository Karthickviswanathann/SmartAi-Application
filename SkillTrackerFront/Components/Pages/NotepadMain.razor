@using Microsoft.AspNetCore.Components
@using static SkillTrackerFront.Components.Pages.AiPanel

@if (Note == null)
{
    <div class="flex-1 flex items-center justify-center bg-background">
        <div class="text-center text-muted-foreground">
            <div class="text-4xl mb-2">📖</div>
            <p class="text-lg font-medium">Select a note or create a new one</p>
        </div>
    </div>
}
else
{
    <div class="flex-1 flex flex-col bg-background min-w-0">

        <!-- Toolbar -->
        <div class="flex items-center gap-2 px-4 py-2 border-b flex-wrap">

            <select class="h-8 text-xs border rounded"
                    @onchange="ChangeCategory">
                @foreach (var c in Categories)
                {
                    <option value="@c" selected="@(Note.Category == c)">
                        @c
                    </option>
                }
            </select>

            <button class="h-8 w-8"
                    @onclick="TogglePin">
                @(Note.IsPinned ? "📌" : "📍")
            </button>

            <button class="h-8 w-8"
                    @onclick="CopyContent">
                @(Copied ? "✅" : "📋")
            </button>

            <div class="flex-1"></div>

            <span class="text-xs text-muted-foreground">
                @WordCount words
            </span>

            <span class="text-xs @(Saved ? "text-green-600" : "text-gray-400")">
                @(Saved ? "✓ Saved" : "Saving...")
            </span>

        </div>

        <!-- Title -->
        <div class="px-4 pt-4 pb-2">
            <input value="@Note.Title"
                   @oninput="UpdateTitle"
                   class="text-2xl font-bold border-none p-0 w-full"
                   placeholder="Note title..."
                   style="font-family:@FontFamily" />
        </div>

        <!-- Content -->
        <div class="flex-1 px-4 pb-4 min-h-0">
            <textarea class="w-full h-full resize-none border rounded-lg p-4"
                      value="@Note.Content"
                      @oninput="UpdateContent"
                      placeholder="Start writing..."
                      style="font-family:@FontFamily;font-size:@FontSize;line-height:1.7">
            </textarea>
        </div>

        <!-- AI Toolbar -->
        <div class="px-4 pb-4 flex gap-2 flex-wrap">

            <button class="border rounded px-2 py-1 text-xs"
                    @onclick="() => RunAi(summarize)">
                ✨ Summarize
            </button>

            <button class="border rounded px-2 py-1 text-xs"
                    @onclick="() => RunAi(explain)">
                📖 Explain
            </button>

            <button class="border rounded px-2 py-1 text-xs"
                    @onclick="() => RunAi(improve)">
                ✏ Improve
            </button>

            <button class="border rounded px-2 py-1 text-xs"
                    @onclick="() => RunAi(interview)">
                ❓ Interview Q&A
            </button>


        </div>

    </div>
}

@code {

    [Parameter] public Notes Note { get; set; }

    [Parameter] public EventCallback<Notes> NoteChanged { get; set; }

    AiStateService AiState = new AiStateService();

    bool Saved = true;
    bool Copied = false;

    string FontFamily = "Arial";
    int FontSize = 16;

    string[] Categories =
    {
        "General","Work","Personal","Ideas","Meeting Notes","Research"
    };

    string summarize = "summarize";
    string explain = "explain";
    string improve = "improve";
    string interview = "interview";


    int WordCount =>
        string.IsNullOrWhiteSpace(Note?.Content)
        ? 0
        : Note.Content.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;

    async Task TogglePin()
    {
        Note.IsPinned = !Note.IsPinned;
        await NoteChanged.InvokeAsync(Note);
    }

    async Task ChangeCategory(ChangeEventArgs e)
    {
        Note.Category = e.Value?.ToString();
        await NoteChanged.InvokeAsync(Note);
    }

    async Task UpdateTitle(ChangeEventArgs e)
    {
        Saved = false;
        Note.Title = e.Value?.ToString();
        await NoteChanged.InvokeAsync(Note);
        Saved = true;
    }

    async Task UpdateContent(ChangeEventArgs e)
    {
        Saved = false;
        Note.Content = e.Value?.ToString();
        await NoteChanged.InvokeAsync(Note);
        Saved = true;
    }

    async Task CopyContent()
    {
        Copied = true;
        await Task.Delay(2000);
        Copied = false;
    }

    void RunAi(string action)
    {


        AiState.AiPanelOpen = true;
        AiState.AiLoading = true;

        AiState.AiContent = "AI is generating response...";
        AiState.Notify();

        Console.WriteLine($"AI Action: {action}");
        // call AI API here
    }


    public class Notes
    {
        public int Id { get; set; }

        public string Title { get; set; }

        public string Content { get; set; }
        public string Category { get; set; }

        public DateTime CreatedDate { get; set; }

        public DateTime? UpdatedDate { get; set; }

        public bool IsPinned { get; set; }

        public bool IsDeleted { get; set; }
    }

    public class AiStateService
    {
        public bool AiPanelOpen { get; set; }

        public string AiContent { get; set; } = "";

        public bool AiLoading { get; set; }

        public event Action? OnChange;

        public void Notify() => OnChange?.Invoke();
    }
}