

@using static SkillTrackerFront.Components.Pages.NotepadMain


@if (appState.SidebarOpen)
{
    <aside class="w-72 lg:w-80 h-full bg-sidebar border-r border-sidebar-border flex flex-col overflow-hidden">

        <div class="p-4 flex items-center gap-2 border-b border-sidebar-border">
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
                <i class="bi bi-brain"></i>
            </div>
            <span class="font-bold text-lg text-sidebar-foreground">SmartNote AI</span>
        </div>

        <div class="p-3 space-y-2">
            <button class="btn btn-primary w-full" @onclick="AddNote">
                New Note
            </button>

            <input class="form-control"
                   placeholder="Search notes..."
                   @bind="search" />
        </div>

        <div class="flex-1 overflow-y-auto px-2">
            @foreach (var note in FilteredNotes)
            {
                <button class="w-full text-left px-3 py-2 rounded-lg"
                        @onclick="() => SetActiveNote(note.Id)">

                    <div class="flex-1">
                        <div>
                            @if (note.IsPinned)
                            {
                                <span>📌</span>
                            }
                        <span>@note.Title</span>
                    </div>

                    <p class="text-xs text-muted">
                        @(string.IsNullOrEmpty(note.Content) ? "Empty note" :
                                            note.Content.Length > 50 ? note.Content.Substring(0, 50) : note.Content)
                </p>
            </div>

                    <button @onclick="() => DeleteNote(note.Id)">
                        🗑
                    </button>

                </button>
                }
        </div>

        <div class="p-3 border-top">

            <div class="flex justify-between">
                <span>Theme</span>
                <button @onclick="ToggleDark">
                    @(appState.IsDark ? "☀" : "🌙")
                </button>
            </div>

            <div>
                <span>Accent Color</span>

                @foreach (var c in ColorPresets)
                {
                    <button style="background:@c;width:20px;height:20px;border-radius:50%"
                            @onclick="() => SetPrimaryColor(c)">
                    </button>
                }
            </div>

            <select @bind="appState.FontFamily">
                @foreach (var f in FontFamilies)
                {
                    <option value="@f">@f</option>
                }
            </select>

            <select @bind="appState.FontSize">
                @foreach (var s in FontSizes)
                {
                    <option value="@s">@s px</option>
                }
            </select>

           
            <button class="btn btn-danger w-full" @onclick="Logout">
                Sign Out
            </button>

        </div>

    </aside>
}

@code {

    public class AppState
    {
        public List<Notes> Notes { get; set; } = new();

        public int ActiveNoteId { get; set; }

        public bool SidebarOpen { get; set; } = true;

        public bool IsDark { get; set; }

        public string PrimaryColor { get; set; }

        public string FontFamily { get; set; } = "Inter";

        public int FontSize { get; set; } = 16;

        public void AddNote() { }

        public void DeleteNote(int id) { }

        public void ToggleDark()
        {
            IsDark = !IsDark;
        }

        public void Logout() { }
    }


    AppState appState = new AppState();


    string search = "";

    List<string> FontFamilies = new()
    {
        "Inter","Arial","Times New Roman","Courier New","Verdana"
    };

    List<int> FontSizes = new() { 14, 16, 18, 20 };

    List<string> ColorPresets = new()
    {
        "#4F7FFF","#10B981","#F59E0B","#EF4444","#8B5CF6","#EC4899","#06B6D4"
    };

    IEnumerable<Notes> FilteredNotes =>
        appState.Notes
        .Where(n =>
            (n.Title?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (n.Content?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderByDescending(n => n.IsPinned);

    void AddNote() => appState.AddNote();

    void DeleteNote(int id) => appState.DeleteNote(id);

    void SetActiveNote(int id) => appState.ActiveNoteId = id;

    void ToggleDark() => appState.ToggleDark();

    void SetPrimaryColor(string color) => appState.PrimaryColor = color;

    void Logout() => appState.Logout();
}